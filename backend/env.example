# ─────────────────────────────────────────────────────────
# Environment Variables — Denso Dashboard Backend
# Di Render: masukkan ini satu per satu di Environment tab
# ─────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=production

# Data mode: "mock" = dummy data (tidak perlu database)
DATA_MODE=mock

# JWT — WAJIB diganti dengan string random panjang!
# Generate di: https://www.uuidgenerator.net/ atau pakai 2-3 UUID digabung
JWT_SECRET=ganti_dengan_string_random_panjang_minimal_32_karakter
JWT_EXPIRES_IN=8h

# URL Frontend Vercel kamu — WAJIB diisi!
FRONTEND_URL=https://production-dashboard-project-tfcu-avki0943y.vercel.app
