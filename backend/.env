# ─────────────────────────────────────────────
# .env.example — Copy file ini menjadi .env
# dan isi sesuai konfigurasi server Denso lu
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# SQL Server (sesuaikan dengan server Denso)
DB_SERVER=localhost
DB_DATABASE=DensoDashboard
DB_USER=sa
DB_PASSWORD=YourPassword123
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true

# JWT Secret — ganti dengan string random yang panjang!
JWT_SECRET=denso_ped_super_secret_jwt_key_2025
JWT_EXPIRES_IN=8h

# Frontend URL (untuk CORS)
FRONTEND_URL=https://production-dashboard-project-tfcu-avki0943y.vercel.app

# Mode: "mock" = pakai dummy data, "real" = pakai SQL Server beneran
# Kalau SQL Server belum siap, set ke "mock" dulu
DATA_MODE=mock
